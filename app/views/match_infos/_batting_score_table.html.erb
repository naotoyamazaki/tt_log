<%
  theme      = local_assigns.fetch(:theme, :legacy)
  is_new     = theme == :player || theme == :opponent
  rate_key   = local_assigns.fetch(:rate_key, nil)
  rate_label = local_assigns.fetch(:rate_label, nil)
  bar_class  = theme == :opponent ? 'rate-bar-fill-opponent' : 'rate-bar-fill-player'
  rank_cls   = theme == :opponent ? 'rank-badge-opponent'    : 'rank-badge-player'
  header_cls = case theme
               when :player   then 'ranking-table-player-header'
               when :opponent then 'ranking-table-opponent-header'
               end
  score_key  = theme == :opponent ? :lost_score : :score
%>

<div class="overflow-auto d-md-none">
  <table class="table text-nowrap mb-0">
    <thead class="<%= header_cls %>">
      <tr>
        <th class="text-center rank-col">#</th>
        <th>技術</th>
        <th class="text-center">得点数</th>
        <% if is_new %>
          <th class="text-center">使用率</th>
        <% else %>
          <th class="text-center">失点数</th>
          <th class="text-center"><%= rate_label %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% data.each.with_index(1) do |score_data, rank| %>
        <tr>
          <td class="text-center"><span class="rank-badge <%= rank_cls %>"><%= rank %></span></td>
          <td><%= abbreviate_batting_style(Score.human_enum_name(:batting_style, score_data[:batting_style])) %></td>
          <td class="text-center"><%= score_data[score_key] %></td>
          <% if is_new %>
            <td class="text-center"><strong><%= score_data[:share] %>%</strong></td>
          <% else %>
            <td class="text-center"><%= score_data[:lost_score] %></td>
            <td class="text-center"><strong><%= "#{score_data[rate_key]}%" %></strong></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<table class="table d-none d-md-table mb-0">
  <thead class="<%= header_cls %>">
    <tr>
      <th class="text-center rank-col">#</th>
      <th>技術名</th>
      <th class="text-end">得点数</th>
      <% unless is_new %>
        <th class="text-end">失点数</th>
        <th class="text-end"><%= rate_label %></th>
      <% end %>
      <th class="rate-bar-col <%= is_new ? 'text-end' : '' %>"><%= is_new ? '使用率' : '' %></th>
    </tr>
  </thead>
  <tbody>
    <% data.each.with_index(1) do |score_data, rank| %>
      <tr>
        <td class="text-center"><span class="rank-badge <%= rank_cls %>"><%= rank %></span></td>
        <td><%= Score.human_enum_name(:batting_style, score_data[:batting_style]) %></td>
        <td class="text-end"><%= score_data[score_key] %></td>
        <% unless is_new %>
          <td class="text-end"><%= score_data[:lost_score] %></td>
          <td class="text-end"><strong><%= "#{score_data[rate_key]}%" %></strong></td>
        <% end %>
        <td class="align-middle">
          <% bar_width = is_new ? score_data[:share] : score_data[rate_key] %>
          <div class="d-flex align-items-center gap-2">
            <div class="rate-bar-container flex-grow-1">
              <div class="<%= bar_class %>" style="width: <%= bar_width %>%;"></div>
            </div>
            <% if is_new %>
              <span class="rate-bar-pct"><%= bar_width %>%</span>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
