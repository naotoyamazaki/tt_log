<% match_info.games.order(:game_number).each do |game| %>
  <% game_scores = game.scores.where.not(batting_style: :receive) %>
  <% next if game_scores.empty? %>
  <% ranked_data = calculate_batting_score_data(game_scores).reject { |d| d[:score] == 0 && d[:lost_score] == 0 } %>
  <% next if ranked_data.empty? %>

  <% won = game.player_score > game.opponent_score %>
  <div class="game-breakdown-card mb-4">
    <div class="game-breakdown-header <%= won ? 'game-breakdown-won' : 'game-breakdown-lost' %>">
      <span class="game-breakdown-title">第<%= game.game_number %>ゲーム</span>
      <span class="game-breakdown-score"><%= game.player_score %>-<%= game.opponent_score %></span>
    </div>

    <div class="overflow-auto d-md-none">
      <table class="table text-nowrap mb-0">
        <thead>
          <tr>
            <th>技術</th>
            <th>得点</th>
            <th>失点</th>
            <th>得点率</th>
          </tr>
        </thead>
        <tbody>
          <% ranked_data.each do |data| %>
            <tr>
              <td><%= abbreviate_batting_style(Score.human_enum_name(:batting_style, data[:batting_style])) %></td>
              <td><%= data[:score] %></td>
              <td><%= data[:lost_score] %></td>
              <td><%= "#{data[:rate]}%" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <table class="table d-none d-md-table mb-0">
      <thead>
        <tr>
          <th>技術</th>
          <th class="text-end">得点数</th>
          <th class="text-end">失点数</th>
          <th class="text-end">得点率</th>
        </tr>
      </thead>
      <tbody>
        <% ranked_data.each do |data| %>
          <tr>
            <td><%= Score.human_enum_name(:batting_style, data[:batting_style]) %></td>
            <td class="text-end"><%= data[:score] %></td>
            <td class="text-end"><%= data[:lost_score] %></td>
            <td class="text-end"><%= "#{data[:rate]}%" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
