<%
  # ゲーム番号ごとにラリーデータをグループ化
  rallies_by_game = match_info.rallies.order(:game_number, :sequence_number).group_by(&:game_number)
%>

<% rallies_by_game.each do |game_number, rallies| %>
  <%
    max_seq = rallies.map(&:sequence_number).max
    rallies_map = rallies.index_by(&:sequence_number)
    player_name = match_info.player.player_name
    opponent_name = match_info.opponent.player_name
  %>
  <div class="score-progression-game mb-4">
    <div class="score-progression-game-title"><%= game_number %>ゲーム目</div>
    <div class="score-progression-scroll-wrapper">
      <table class="score-progression-table">
        <thead>
          <tr>
            <th class="score-progression-name-col"></th>
            <% (1..max_seq).each do |seq| %>
              <th class="score-progression-seq-col"><%= seq %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <!-- 選手（player）行 -->
          <tr>
            <td class="score-progression-name-cell score-progression-player-name"><%= player_name %></td>
            <% (1..max_seq).each do |seq| %>
              <% rally = rallies_map[seq] %>
              <% if rally && rally.player? %>
                <% info = batting_style_abbr_info(rally.batting_style) %>
                <td class="score-progression-cell score-progression-cell-player score-progression-cell-abbr"
                    data-label="<%= info[:label] %>"
                    title="<%= info[:label] %>"><%= info[:abbr_ja] || info[:abbr] %></td>
              <% else %>
                <td class="score-progression-cell"></td>
              <% end %>
            <% end %>
          </tr>
          <!-- 相手（opponent）行 -->
          <tr>
            <td class="score-progression-name-cell score-progression-opponent-name"><%= opponent_name %></td>
            <% (1..max_seq).each do |seq| %>
              <% rally = rallies_map[seq] %>
              <% if rally && rally.opponent? %>
                <% info = batting_style_abbr_info(rally.batting_style) %>
                <td class="score-progression-cell score-progression-cell-opponent score-progression-cell-abbr"
                    data-label="<%= info[:label] %>"
                    title="<%= info[:label] %>"><%= info[:abbr_ja] || info[:abbr] %></td>
              <% else %>
                <td class="score-progression-cell"></td>
              <% end %>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<script>
  (function () {
    function initScoreProgression() {
      document.querySelectorAll('.score-progression-scroll-wrapper').forEach(function (wrapper) {
        if (wrapper.scrollWidth > wrapper.clientWidth) {
          wrapper.classList.add('scrollable');
          setTimeout(function () {
            wrapper.scrollLeft = 40;
            setTimeout(function () { wrapper.scrollLeft = 0; }, 300);
          }, 500);
          wrapper.addEventListener('scroll', function () {
            if (wrapper.scrollLeft + wrapper.clientWidth >= wrapper.scrollWidth - 2) {
              wrapper.classList.remove('scrollable');
            } else {
              wrapper.classList.add('scrollable');
            }
          });
        }
      });

      document.querySelectorAll('.score-progression-cell-abbr').forEach(function (cell) {
        cell.style.cursor = 'pointer';
        cell.addEventListener('click', function () {
          var existing = cell.querySelector('.abbr-tooltip');
          if (existing) { existing.remove(); return; }
          var tip = document.createElement('span');
          tip.className = 'abbr-tooltip';
          tip.textContent = cell.dataset.label;
          cell.appendChild(tip);
          setTimeout(function () { if (tip.parentNode) tip.remove(); }, 1500);
        });
      });
    }

    document.addEventListener('turbo:load', initScoreProgression);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScoreProgression);
    } else {
      initScoreProgression();
    }
  }());
</script>
