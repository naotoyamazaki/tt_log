<% saved_games ||= [] %>
<% max_games ||= 5 %>
<% player_wins = saved_games.count { |g| g.player_score.to_i > g.opponent_score.to_i } %>
<% opponent_wins = saved_games.count { |g| g.opponent_score.to_i > g.player_score.to_i } %>

<div class="scoreboard-container">
  <div class="scoreboard-header">
    <div class="scoreboard-player-name" data-scoreboard-target="playerName">選手名</div>
    <span class="scoreboard-vs">VS</span>
    <div class="scoreboard-opponent-name" data-scoreboard-target="opponentName">対戦相手</div>
  </div>

  <div class="scoreboard-display">
    <!-- 左側：選手の得点 -->
    <div class="scoreboard-section scoreboard-left">
      <div class="scoreboard-label">得点数</div>
      <div class="scoreboard-score" data-scoreboard-target="playerPoints">0</div>
    </div>

    <!-- 中央：ゲーム数とスコアリスト -->
    <div class="scoreboard-section scoreboard-center">
      <div class="scoreboard-label">ゲーム数</div>
      <div class="game-scores-container">
        <div class="game-wins-left" data-scoreboard-target="playerWins"><%= player_wins %></div>
        <div class="game-history" data-scoreboard-target="gameHistory">
          <% 7.times do |i| %>
            <% game = saved_games[i] %>
            <% hidden = i >= max_games ? ' d-none' : '' %>
            <% if game %>
              <% ps = game.player_score.to_i; os = game.opponent_score.to_i %>
              <div class="game-score-result <%= ps > os ? 'game-won' : 'game-lost' %><%= hidden %>"
                   data-game-idx="<%= i %>"
                   data-scoreboard-target="gameSlot">
                <%= "#{ps}-#{os}" %>
              </div>
            <% else %>
              <div class="game-score-placeholder<%= hidden %>"
                   data-game-idx="<%= i %>"
                   data-scoreboard-target="gameSlot">ー</div>
            <% end %>
          <% end %>
        </div>
        <div class="game-wins-right" data-scoreboard-target="opponentWins"><%= opponent_wins %></div>
      </div>
    </div>

    <!-- 右側：対戦相手の得点 -->
    <div class="scoreboard-section scoreboard-right">
      <div class="scoreboard-label">得点数</div>
      <div class="scoreboard-score" data-scoreboard-target="opponentPoints">0</div>
    </div>
  </div>
</div>
