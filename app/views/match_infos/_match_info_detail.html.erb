<div class="show-container fade-in-up">
  <div id="<%= dom_id match_info %>">

    <div class="section-card p-4 shadow-sm mb-4">
      <h2 class="section-title mb-3">試合情報</h2>
      <div class="row mb-2">
        <div class="column">
          <strong>日付:</strong>
          <%= match_info.match_date %>
        </div>
        <div class="column">
          <strong>大会名:</strong>
          <%= match_info.match_name %>
        </div>
      </div>

      <div class="row mb-2">
        <div class="column">
          <strong>選手名:</strong>
          <%= match_info.player.player_name %>
        </div>
        <div class="column">
          <strong>対戦相手名:</strong>
          <%= match_info.opponent.player_name %>
        </div>
      </div>

      <p>
        <strong>Memo:</strong>
        <%= match_info.memo %>
      </p>
    </div>

    <!-- ▼ ゲーム別スコア・得点推移セクション -->
    <% if match_info.games.any? %>
      <div class="section-card p-4 shadow-sm mb-4">
        <h2 class="section-title mb-3">ゲーム別スコア <span class="game-count-badge ms-2"><%= match_info.game_count_score %></span></h2>
        <%= render partial: "game_score_summary", locals: { match_info: match_info } %>
      </div>

      <div class="section-card p-4 shadow-sm mb-4">
        <h2 class="section-title mb-3">ゲーム別得点推移</h2>
        <%= render partial: "game_score_breakdown", locals: { match_info: match_info } %>
      </div>
    <% end %>

    <div class="section-card p-4 shadow-sm mb-4">
      <div class="ranking-section">
        <h3 class="section-title mb-3">技術ごとの得点率ランキング</h3>
        <div class="overflow-auto d-md-none">
          <table class="table text-nowrap">
            <thead>
              <tr>
                <th>技術</th>
                <th>得点率</th>
                <th>得点数</th>
                <th>失点数</th>
              </tr>
            </thead>
            <tbody>
              <% calculate_batting_score_data(@batting_scores).each do |data| %>
                <tr>
                  <td><%= abbreviate_batting_style(Score.human_enum_name(:batting_style, data[:batting_style])) %></td>
                  <td><%= "#{data[:rate]}%" %></td>
                  <td><%= data[:score] %></td>
                  <td><%= data[:lost_score] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <table class="table d-none d-md-table">
          <thead>
            <tr>
              <th>技術</th>
              <th class="text-end">得点率</th>
              <th class="text-end">得点数</th>
              <th class="text-end">失点数</th>
            </tr>
          </thead>
          <tbody>
            <% calculate_batting_score_data(@batting_scores).each do |data| %>
              <tr>
                <td><%= Score.human_enum_name(:batting_style, data[:batting_style]) %></td>
                <td class="text-end"><%= "#{data[:rate]}%" %></td>
                <td class="text-end"><%= data[:score] %></td>
                <td class="text-end"><%= data[:lost_score] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <div class="advice-section">
          <p><%= @advice %></p>
        </div>
      </div>
    </div>

  </div>
</div>
