<div class="show-container fade-in-up">
  <div id="<%= dom_id match_info %>">

    <div class="section-card p-4 shadow-sm mb-4">
      <h2 class="section-title mb-3">試合情報</h2>
      <div class="row mb-2">
        <div class="column">
          <strong>日付:</strong>
          <%= match_info.match_date %>
        </div>
        <div class="column">
          <strong>大会名:</strong>
          <%= match_info.match_name %>
        </div>
      </div>

      <div class="row mb-2">
        <div class="column">
          <strong>選手名:</strong>
          <%= match_info.player.player_name %>
        </div>
        <div class="column">
          <strong>対戦相手名:</strong>
          <%= match_info.opponent.player_name %>
        </div>
      </div>

      <p>
        <strong>Memo:</strong>
        <%= match_info.memo %>
      </p>
    </div>

    <!-- ▼ ゲーム別スコア・得点推移セクション -->
    <% if match_info.games.any? %>
      <div class="section-card p-4 shadow-sm mb-4">
        <h2 class="section-title mb-3">ゲーム別スコア <span class="game-count-badge ms-2"><%= match_info.game_count_score %></span></h2>
        <%= render partial: "game_score_summary", locals: { match_info: match_info } %>
      </div>

      <div class="section-card p-4 shadow-sm mb-4">
        <h2 class="section-title mb-3">ゲーム別得点率</h2>
        <%= render partial: "game_score_breakdown", locals: { match_info: match_info } %>
      </div>
    <% end %>

    <div class="section-card p-4 shadow-sm mb-4">
      <div class="ranking-section">
        <h3 class="section-title mb-3">技術ごとの得点率ランキング</h3>
        <% has_rally_data = @match_info.games.any? { |game| game.rallies.any? } %>

        <% if has_rally_data %>
          <div class="ranking-section-header ranking-section-header-player mb-2">
            <i class="bi bi-person-fill me-1"></i>自分の得点技術ランキング
          </div>
          <%= render partial: "batting_score_table",
                     locals: { data: player_scoring_techniques(@batting_scores),
                               theme: :player } %>

          <div class="ranking-section-header ranking-section-header-opponent mt-4 mb-2">
            <i class="bi bi-shield-fill me-1"></i>相手の得点技術ランキング
          </div>
          <%= render partial: "batting_score_table",
                     locals: { data: opponent_scoring_techniques(@batting_scores),
                               theme: :opponent } %>
        <% else %>
          <% ranked_data = calculate_batting_score_data(@batting_scores) %>
          <%= render partial: "batting_score_table",
                     locals: { data: ranked_data,
                               rate_key: :rate,
                               rate_label: "得点率" } %>
        <% end %>

      </div>
    </div>

  </div>
</div>
