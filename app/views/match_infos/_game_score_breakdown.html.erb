<% match_info.games.order(:game_number).each do |game| %>
  <% game_scores = game.scores.reject { |score| score.batting_style == "receive" } %>
  <% next if game_scores.empty? %>
  <% has_rally_data = game.rallies.any? %>
  <% ranked_data = calculate_batting_score_data(game_scores).reject { |data| data[:score].zero? && data[:lost_score].zero? } %>
  <% player_ranked_data = player_scoring_techniques(game_scores) %>
  <% opponent_ranked_data = opponent_scoring_techniques(game_scores) %>
  <% next if has_rally_data ? player_ranked_data.empty? && opponent_ranked_data.empty? : ranked_data.empty? %>

  <% won = game.player_score > game.opponent_score %>
  <div class="game-breakdown-card mb-4">
    <div class="game-breakdown-header <%= won ? 'game-breakdown-won' : 'game-breakdown-lost' %>">
      <span class="game-breakdown-title">第<%= game.game_number %>ゲーム</span>
      <span class="game-breakdown-score"><%= game.player_score %>-<%= game.opponent_score %></span>
    </div>

    <% if has_rally_data %>
      <div class="ranking-section-header ranking-section-header-player mt-3 mb-2">
        <i class="bi bi-person-fill me-1"></i>自分の得点技術
      </div>
      <%= render partial: "batting_score_table",
                 locals: { data: player_ranked_data,
                           rate_key: :rate,
                           rate_label: "得点率",
                           theme: :player } %>

      <div class="ranking-section-header ranking-section-header-opponent mt-3 mb-2">
        <i class="bi bi-shield-fill me-1"></i>相手の得点技術
      </div>
      <%= render partial: "batting_score_table",
                 locals: { data: opponent_ranked_data,
                           rate_key: :opponent_rate,
                           rate_label: "相手得点率",
                           theme: :opponent } %>
    <% else %>
      <%= render partial: "batting_score_table",
                 locals: { data: ranked_data,
                           rate_key: :rate,
                           rate_label: "得点率" } %>
    <% end %>
  </div>
<% end %>
