<div class="form-container fade-in-up">
  <%= form_with(model: match_info, data: { controller: "scoreboard" }) do |form| %>

    <%= render 'shared/error_messages', object: @match_info %>

    <div class="row mb-3">
      <div class="column">
        <%= form.label :"🗓️日付" %>
        <%= form.date_field :match_date , class: "form-control rounded-pill shadow-sm"%>
      </div>

      <div class="column">
        <%= form.label :"🏆大会名" %>
        <%= form.text_field :match_name, class: "form-control rounded-pill shadow-sm", placeholder: "出場した大会名を入力" %>
      </div>
    </div>

    <div class="row mb-3">
      <div class="column">
        <%= form.label :"👤選手名" %>
        <%= form.text_field :player_name,
          class: "form-control rounded-pill shadow-sm",
          placeholder: "分析する選手名を入力",
          data: { scoreboard_target: "playerNameInput", action: "input->scoreboard#updateNames" } %>
      </div>

      <div class="column">
        <%= form.label :"👤対戦相手名" %>
        <%= form.text_field :opponent_name,
          class: "form-control rounded-pill shadow-sm",
          placeholder: "対戦相手の名前を入力",
          data: { scoreboard_target: "opponentNameInput", action: "input->scoreboard#updateNames" } %>
      </div>
    </div>

    <div class="mb-4">
      <%= form.label :"🗒️メモ" %>
      <%= form.text_area :memo, class: "wide-textarea form-control rounded-pill shadow-sm", placeholder: "対戦相手の戦型や使用用具、分析していて気になったプレーなどを入力" %>
    </div>

    <% games = match_info.games.order(:game_number) %>

    <% batting_styles_order = %w[
      serve receive
      fore_drive_vs_topspin back_drive_vs_topspin
      fore_drive_vs_backspin back_drive_vs_backspin
      fore_push back_push
      fore_stop back_stop
      fore_flick back_flick
      chiquita
      fore_block back_block
      fore_counter back_counter
      fore_smash back_smash
      net_or_edge
    ] %>

    <% batting_style_options = [
      ['サーブ', 'serve'], ['レシーブ', 'receive'],
      ['対上回転フォアドライブ', 'fore_drive_vs_topspin'], ['対上回転バックドライブ', 'back_drive_vs_topspin'],
      ['対下回転フォアドライブ', 'fore_drive_vs_backspin'], ['対下回転バックドライブ', 'back_drive_vs_backspin'],
      ['フォアツッツキ', 'fore_push'], ['バックツッツキ', 'back_push'],
      ['フォアストップ', 'fore_stop'], ['バックストップ', 'back_stop'],
      ['フォアフリック', 'fore_flick'], ['バックフリック', 'back_flick'],
      ['チキータ', 'chiquita'], ['フォアブロック', 'fore_block'],
      ['バックブロック', 'back_block'], ['フォアカウンター', 'fore_counter'],
      ['バックカウンター', 'back_counter'],
      ['フォアスマッシュ', 'fore_smash'], ['バックスマッシュ', 'back_smash'],
      ['ネットorエッジ', 'net_or_edge']
    ] %>

    <% if games.any? %>

      <div class="analysis-header mb-3 p-3 rounded">
        <h3 class="text-center">ゲーム別得点編集</h3>
        <div>
          編集したいゲームのタブを選択して、各技術の得点・失点数を修正してください。
        </div>
      </div>

      <%= render 'match_infos/scoreboard',
                 saved_games: games,
                 max_games: match_info.match_format || 5 %>

      <ul class="nav nav-tabs mb-3" id="gameEditTabs" role="tablist">
        <% games.each_with_index do |game, idx| %>
          <li class="nav-item" role="presentation">
            <button class="nav-link <%= idx == 0 ? 'active' : '' %>"
                    id="game-tab-<%= game.id %>"
                    data-bs-toggle="tab"
                    data-bs-target="#game-panel-<%= game.id %>"
                    data-player-score="<%= game.player_score.to_i %>"
                    data-opponent-score="<%= game.opponent_score.to_i %>"
                    data-game-idx="<%= idx %>"
                    data-scoreboard-target="gameTab"
                    type="button"
                    role="tab"
                    aria-controls="game-panel-<%= game.id %>"
                    aria-selected="<%= idx == 0 ? 'true' : 'false' %>">
              ゲーム<%= game.game_number %>
              <span class="badge bg-secondary ms-1">
                <%= game.player_score.to_i %>-<%= game.opponent_score.to_i %>
              </span>
            </button>
          </li>
        <% end %>
      </ul>

      <div class="tab-content" id="gameEditTabsContent">
        <% games.each_with_index do |game, idx| %>
          <div class="tab-pane fade <%= idx == 0 ? 'show active' : '' %>"
               id="game-panel-<%= game.id %>"
               role="tabpanel"
               aria-labelledby="game-tab-<%= game.id %>">

            <%= form.fields_for :games, game do |game_form| %>
              <% sorted_game_scores = game.scores.sort_by { |s| batting_styles_order.index(s.batting_style) || 999 } %>
              <% sorted_game_scores.each do |score| %>
                <%= game_form.fields_for :scores, score do |score_form| %>
                  <div class="batting-style-card card mb-3 p-3">
                    <%= score_form.select :batting_style,
                        batting_style_options,
                        {},
                        { class: "form-control medium-input" } %>
                    <%= render 'scores/score_fields', score_form: score_form, score: score %>
                  </div>
                <% end %>
              <% end %>
            <% end %>

          </div>
        <% end %>
      </div>

    <% else %>

      <div class="analysis-header mb-4 p-3 rounded">
        <h3 class="text-center">分析フォームの使い方</h3>
        <div>
          試合で使用した<strong>各技術（サーブ含む）</strong>の得点率を分析します。<br>
          例：分析する選手がサービスエースで得点 → サーブの得点数に1をプラスする。<br>
          例：分析する選手がサービスミスで失点 → サーブの失点数に1をプラスする。<br>
          例：分析する選手がフォアドライブで得点 → フォアドライブの得点数に1をプラスする。<br>
          例：分析する選手がフォアドライブで失点 → フォアドライブの失点数に1をプラスする。
        </div>
      </div>

      <% sorted_scores = match_info.scores.sort_by { |score| batting_styles_order.index(score.batting_style) || 999 } %>

      <% sorted_scores.each do |score| %>
        <%= form.fields_for :scores, score do |score_form| %>
          <div class="batting-style-card card mb-3 p-3">
            <%= score_form.select :batting_style,
                batting_style_options,
                {},
                { class: "form-control medium-input" } %>

            <% case score.batting_style %>
            <% when "serve", "receive",
                  "fore_drive_vs_topspin", "back_drive_vs_topspin",
                  "fore_drive_vs_backspin", "back_drive_vs_backspin",
                  "fore_push", "back_push", "fore_stop", "back_stop",
                  "fore_flick", "back_flick", "chiquita",
                  "fore_block", "back_block",
                  "fore_counter", "back_counter",
                  "fore_smash", "back_smash", "net_or_edge" %>
              <%= render 'scores/score_fields', score_form: score_form, score: score %>
            <% end %>
          </div>
        <% end %>
      <% end %>

    <% end %>

    <div class="center-text">
      <%= form.submit "🚀 試合を分析する", class: "btn btn-success px-4 py-2 mt-4 rounded-pill shadow" %>
    </div>
  <% end %>
</div>
